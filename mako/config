# vim: syntax=toml

# LOOKS
output=*
font=InconsolataGo Nerd Font 14
default-timeout=5000
background-color=#282828
text-color=#ebdbb2
border-radius=6
margin=10

# POSITIONING
anchor=top-right
layer=overlay

# --- Low Urgency (Info - Green) ---
[urgency=low]
border-color=#98971a

# --- Normal Urgency (Warning - Yellow) ---
[urgency=normal]
border-color=#d79921

# --- Critical Urgency (Error - Red) ---
[urgency=critical]
border-color=#cc241d
default-timeout=0

[hidden]
border-color=#458588
